        "        / exact_matches[\"int_unit_price\"].replace(0, np.nan)\n",
        "    )\n",
        "    exact_matches[\"mv_diff\"]        = (\n",
        "        exact_matches[\"int_market_value\"] - exact_matches[\"cst_market_value\"]\n",
        "    )\n",
