        "                score_cutoff=threshold,\n",
        "            )\n",
        "            if match_result:\n",
        "                matched_name, score, match_idx = match_result\n",
        "                matched_row = missing_internal.iloc[match_idx]\n",
        "                fuzzy_results.append({\n",
        "                    \"int_position_id\":    row.get(\"int_position_id\", \"\"),\n",
        "                    \"cst_position_id\":    matched_row.get(\"cst_position_id\", \"\"),\n",
        "                    \"isin\":               int_isin,\n",
