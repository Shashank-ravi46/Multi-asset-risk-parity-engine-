        "    print(f\"   Threshold: {threshold} | Algorithm: token_sort_ratio\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    if missing_custodian.empty or missing_internal.empty:\n",
        "        print(\"  No residuals to fuzzy match.\")\n",
        "        return {\"fuzzy_matches\": pd.DataFrame(), \"unmatched\": missing_custodian}\n",
        "\n",
        "    # Build lookup: ISIN → custodian security_name for fast lookup\n",
        "    # Fuzzy match on composite key: ISIN + security name similarity\n",
        "    fuzzy_results = []\n",
