        "# ============================================================\n",
        "\n",
        "os.makedirs(\"outputs\", exist_ok=True)\n",
        "\n",
        "# ── CHART 1: WATERFALL — Break Resolution Flow ───────────────\n",
        "def plot_waterfall(master_df: pd.DataFrame):\n",
        "    \"\"\"\n",
        "    Waterfall chart showing how positions flow from total → clean.\n",
        "    Classic ops dashboard view: starts with total, subtract breaks.\n",
        "    \"\"\"\n",
        "    bt = master_df[\"break_type\"].value_counts()\n",
        "\n",
        "    total         = len(master_df)\n",
        "    clean         = bt.get(\"CLEAN_MATCH\", 0)\n",
        "    qty_mis       = bt.get(\"QUANTITY_MISMATCH\", 0)\n",
        "    price_br      = bt.get(\"PRICE_TOLERANCE_BREACH\", 0)\n",
        "    combined      = bt.get(\"QUANTITY_AND_PRICE_BREAK\", 0)\n",
        "    miss_cust     = bt.get(\"MISSING_FROM_CUSTODIAN\", 0) + bt.get(\"MISSING_FROM_CUSTODIAN_UNRESOLVED\", 0)\n",
        "    miss_int      = bt.get(\"MISSING_FROM_INTERNAL\", 0)\n",
        "    naming        = bt.get(\"NAMING_CONVENTION_BREAK\", 0)\n",
        "    routing       = bt.get(\"ACCOUNT_ROUTING_BREAK\", 0)\n",
        "\n",
        "    fig = go.Figure(go.Waterfall(\n",
        "        name=\"Break Resolution\",\n",
        "        orientation=\"v\",\n",
        "        measure=[\n",
        "            \"absolute\", \"relative\", \"relative\", \"relative\",\n",
        "            \"relative\", \"relative\", \"relative\", \"relative\", \"total\"\n",
        "        ],\n",
        "        x=[\n",
        "            \"Total Positions\",\n",
        "            \"Qty Mismatch\",\n",
        "            \"Price Breach\",\n",
        "            \"Combined Break\",\n",
        "            \"Missing: Custodian\",\n",
        "            \"Missing: Internal\",\n",
        "            \"Naming Break\",\n",
        "            \"Account Routing\",\n",
        "            \"Clean Matches\",\n",
        "        ],\n",
        "        y=[\n",
        "            total,\n",
        "            -qty_mis,\n",
        "            -price_br,\n",
        "            -combined,\n",
        "            -miss_cust,\n",
        "            -miss_int,\n",
        "            0,   # Fuzzy-recovered (net neutral)\n",
        "            0,\n",
        "            clean,\n",
        "        ],\n",
        "        text=[\n",
        "            f\"{total:,}\",\n",
        "            f\"-{qty_mis:,}\",\n",
        "            f\"-{price_br:,}\",\n",
        "            f\"-{combined:,}\",\n",
        "            f\"-{miss_cust:,}\",\n",
        "            f\"-{miss_int:,}\",\n",
        "            f\"~{naming:,} recovered\",\n",
        "            f\"~{routing:,} routed\",\n",
        "            f\"{clean:,}\",\n",
        "        ],\n",
        "        textposition=\"outside\",\n",
        "        connector={\"line\": {\"color\": \"rgb(63, 63, 63)\"}},\n",
        "        increasing={\"marker\": {\"color\": \"#2E8B57\"}},  # Green for gains\n",
        "        decreasing={\"marker\": {\"color\": \"#DC143C\"}},  # Red for breaks\n",
        "        totals={\"marker\": {\"color\": \"#1F4E79\"}},       # Navy for totals\n",
        "    ))\n",
        "\n",
        "    fig.update_layout(\n",
        "        title={\n",
        "            \"text\": \"ISA Reconciliation: Break Resolution Waterfall\",\n",
        "            \"x\": 0.5, \"font\": {\"size\": 18, \"color\": \"#1F4E79\"}\n",
        "        },\n",
        "        xaxis_title=\"Break Category\",\n",
        "        yaxis_title=\"Number of Positions\",\n",
        "        height=550,\n",
        "        template=\"plotly_white\",\n",
        "        showlegend=False,\n",
        "        plot_bgcolor=\"white\",\n",
        "        paper_bgcolor=\"white\",\n",
        "    )\n",
        "    fig.write_html(\"outputs/waterfall_chart.html\")\n",
        "    fig.show()\n",
        "    print(\"✅ Waterfall chart saved\")\n",
        "\n",
        "# ── CHART 2: PIE — Break Type Distribution ───────────────────\n",
        "def plot_break_distribution(master_df: pd.DataFrame):\n",
        "    colour_map = {\n",
        "        \"CLEAN_MATCH\":                       \"#2E8B57\",\n",
        "        \"QUANTITY_MISMATCH\":                 \"#FFD700\",\n",
        "        \"PRICE_TOLERANCE_BREACH\":            \"#FFA500\",\n",
