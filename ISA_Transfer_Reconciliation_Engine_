        "# ============================================================\n",
        "# CELL 4: EXACT MATCH ENGINE\n",
        "# Stage 1: pd.merge outer join on ISIN + Account ID\n",
        "# Produces three buckets: matched, missing_custodian, missing_internal\n",
        "# ============================================================\n",
        "\n",
        "def run_exact_match(internal: pd.DataFrame,\n",
        "                    custodian: pd.DataFrame) -> dict:\n",
        "    \"\"\"\n",
        "    Perform exact reconciliation on ISIN + account_id composite key.\n",
        "    Returns a dict of DataFrames for each match category.\n",
        "    \"\"\"\n",
        "    print(\"=\" * 60)\n",
        "    print(\"STAGE 1: EXACT MATCH RECONCILIATION\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    # Rename columns to distinguish source in the merged frame\n",
        "    int_cols = {c: f\"int_{c}\" for c in\n",
        "                [\"quantity\", \"unit_price\", \"market_value\",\n",
        "                 \"security_name\", \"position_id\", \"settlement_date\"]}\n",
        "    cst_cols = {c: f\"cst_{c}\" for c in\n",
        "                [\"quantity\", \"unit_price\", \"market_value\",\n",
