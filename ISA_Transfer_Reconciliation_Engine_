        "    print(\"✅ Break distribution chart saved\")\n",
        "\n",
        "# ── CHART 3: SCATTER — Qty vs Price Discrepancy ──────────────\n",
        "def plot_discrepancy_scatter(master_df: pd.DataFrame):\n",
        "    breaks = master_df[\n",
        "        master_df[\"break_type\"].isin([\n",
        "            \"QUANTITY_MISMATCH\",\n",
        "            \"PRICE_TOLERANCE_BREACH\",\n",
        "            \"QUANTITY_AND_PRICE_BREAK\",\n",
        "        ])\n",
        "    ].copy()\n",
        "\n",
        "    if breaks.empty:\n",
