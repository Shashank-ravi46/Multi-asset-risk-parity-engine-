        "# ============================================================\n",
        "# CELL 3: SYNTHETIC DATA GENERATOR\n",
        "# Produces realistic internal_ledger and custodian_feed\n",
        "# with deliberate, controlled discrepancies\n",
        "# ============================================================\n",
        "\n",
        "def generate_account_id(account_type: str) -> str:\n",
        "    \"\"\"Generate a realistic ISA account identifier.\"\"\"\n",
        "    prefix_map = {\n",
        "        \"STOCKS_ISA\":    \"ISA-S\",\n",
        "        \"CASH_ISA\":      \"ISA-C\",\n",
        "        \"TRANSFER_IN\":   \"TRF-IN\",\n",
        "        \"TRANSFER_OUT\":  \"TRF-OUT\",\n",
        "    }\n",
        "    prefix = prefix_map.get(account_type, \"ACC\")\n",
        "    return f\"{prefix}-{''.join(random.choices(string.digits, k=8))}\"\n",
        "\n",
        "\n",
        "def generate_transfer_date(account_type: str) -> str:\n",
        "    \"\"\"Generate a realistic transfer/settlement date respecting SLA windows.\"\"\"\n",
        "    base_date = datetime(2026, 1, 1)\n",
        "    if account_type in [\"TRANSFER_IN\", \"TRANSFER_OUT\"]:\n",
        "        # Transfers initiated within last 30 days\n",
        "        offset = random.randint(0, 30)\n",
        "    else:\n",
        "        offset = random.randint(0, 90)\n",
        "    return (base_date + timedelta(days=offset)).strftime(\"%Y-%m-%d\")\n",
        "\n",
        "\n",
        "def apply_naming_convention_difference(name: str) -> str:\n",
        "    \"\"\"\n",
        "    Simulate how custodians often abbreviate or reformat security names.\n",
        "    e.g., 'iShares Core MSCI World' → 'ISHARES CORE MSCI WLD ETF'\n",
        "    This is what the fuzzy matcher must recover.\n",
        "    \"\"\"\n",
        "    transformations = [\n",
        "        lambda s: s.upper(),\n",
        "        lambda s: s.replace(\"PLC\", \"\").strip(),\n",
        "        lambda s: s.replace(\"Inc\", \"INC\").replace(\"Corporation\", \"CORP\"),\n",
        "        lambda s: s.replace(\"iShares\", \"ISHARES\").replace(\"Vanguard\", \"VGRD\"),\n",
        "        lambda s: re.sub(r'\\s+', ' ', s.replace(\"Holdings\", \"HLDGS\")),\n",
        "        lambda s: s[:25] + \"...\" if len(s) > 25 else s,  # Truncation\n",
        "        lambda s: s.replace(\" \", \"_\"),                    # Underscore substitution\n",
        "    ]\n",
        "    # Apply 1-2 random transformations\n",
        "    chosen = random.sample(transformations, k=random.randint(1, 2))\n",
        "    for fn in chosen:\n",
        "        name = fn(name)\n",
        "    return name\n",
        "\n",
        "\n",
        "def generate_internal_ledger(n: int) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Generate the internal position ledger (firm's book of record).\n",
        "    Each row = one position: client account × security × quantity × price.\n",
        "    \"\"\"\n",
        "    records = []\n",
        "\n",
        "    # Pre-generate a pool of accounts (realistic — multiple positions per account)\n",
        "    account_pool = []\n",
        "    for acc_type in ISA_ACCOUNT_TYPES:\n",
        "        count = n // len(ISA_ACCOUNT_TYPES)\n",
        "        account_pool.extend([\n",
        "            {\"account_id\": generate_account_id(acc_type),\n",
        "             \"account_type\": acc_type,\n",
        "             \"client_name\": fake.name()}\n",
        "            for _ in range(count // 5)  # Roughly 5 positions per account\n",
        "        ])\n",
        "\n",
        "    for i in range(n):\n",
        "        sec = random.choice(SECURITY_UNIVERSE)\n",
        "        acct = random.choice(account_pool)\n",
        "        quantity = round(random.uniform(1, 5000), 4)\n",
        "        price = round(random.uniform(0.50, 500.00), 4)\n",
        "        market_value = round(quantity * price, 2)\n",
        "        transfer_date = generate_transfer_date(acct[\"account_type\"])\n",
        "\n",
        "        records.append({\n",
        "            \"position_id\":    f\"INT-{i+1:06d}\",\n",
        "            \"isin\":           sec[\"isin\"],\n",
        "            \"security_name\":  sec[\"name\"],\n",
        "            \"sector\":         sec[\"sector\"],\n",
        "            \"currency\":       sec[\"currency\"],\n",
        "            \"account_id\":     acct[\"account_id\"],\n",
        "            \"account_type\":   acct[\"account_type\"],\n",
        "            \"client_name\":    acct[\"client_name\"],\n",
        "            \"quantity\":       quantity,\n",
        "            \"unit_price\":     price,\n",
        "            \"market_value\":   market_value,\n",
        "            \"settlement_date\":transfer_date,\n",
        "            \"source\":         \"INTERNAL\",\n",
        "        })\n",
        "\n",
        "    df = pd.DataFrame(records)\n",
        "    df = df.drop_duplicates(subset=[\"isin\", \"account_id\"])  # One position per ISIN/account\n",
        "    print(f\"✅ Internal ledger: {len(df):,} positions | \"\n",
        "          f\"{df['account_type'].nunique()} account types | \"\n",
        "          f\"£{df[df['currency']=='GBP']['market_value'].sum():,.0f} GBP exposure\")\n",
        "    return df\n",
        "\n",
        "\n",
        "def generate_custodian_feed(internal_df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Generate custodian feed based on internal ledger but with deliberate breaks.\n",
        "    Simulates how a ceding ISA provider's registry report differs from internal books.\n",
        "    \"\"\"\n",
        "    df = internal_df.copy()\n",
        "    n = len(df)\n",
        "    records = df.to_dict('records')\n",
        "    random.shuffle(records)\n",
        "\n",
        "    modified_records = []\n",
        "    excluded_indices = set()  # Tracks positions missing from custodian\n",
        "\n",
        "    for i, rec in enumerate(records):\n",
        "        r = rec.copy()\n",
        "        r[\"source\"] = \"CUSTODIAN\"\n",
        "        r[\"position_id\"] = f\"CST-{i+1:06d}\"\n",
        "\n",
        "        # --- Inject deliberate discrepancies ---\n",
        "\n",
        "        # 1. Missing from custodian (internal has it, custodian doesn't)\n",
        "        if random.random() < CONFIG[\"MISSING_FROM_CUSTODIAN_RATE\"]:\n",
        "            excluded_indices.add(i)\n",
        "            continue  # Skip this record entirely\n",
        "\n",
        "        # 2. Quantity mismatch (rounding errors, fractional share differences)\n",
        "        if random.random() < CONFIG[\"QTY_MISMATCH_RATE\"]:\n",
        "            delta_pct = random.choice([-1, 1]) * random.uniform(0.001, 0.05)\n",
        "            r[\"quantity\"] = round(r[\"quantity\"] * (1 + delta_pct), 4)\n",
        "            r[\"market_value\"] = round(r[\"quantity\"] * r[\"unit_price\"], 2)\n",
        "\n",
        "        # 3. Price tolerance breach (stale pricing, FX mark differences)\n",
        "        if random.random() < CONFIG[\"PRICE_BREACH_RATE\"]:\n",
        "            delta_pct = random.choice([-1, 1]) * random.uniform(0.006, 0.02)\n",
        "            r[\"unit_price\"] = round(r[\"unit_price\"] * (1 + delta_pct), 4)\n",
        "            r[\"market_value\"] = round(r[\"quantity\"] * r[\"unit_price\"], 2)\n",
        "\n",
        "        # 4. Naming convention differences (fuzzy matcher recovers these)\n",
        "        if random.random() < CONFIG[\"NAMING_DIFF_RATE\"]:\n",
        "            r[\"security_name\"] = apply_naming_convention_difference(r[\"security_name\"])\n",
        "\n",
        "        modified_records.append(r)\n",
        "\n",
        "    custodian_df = pd.DataFrame(modified_records)\n",
        "\n",
        "    # 5. Add positions missing from internal (custodian has extras — ghost positions)\n",
        "    n_extra = int(n * CONFIG[\"MISSING_FROM_INTERNAL_RATE\"])\n",
        "    for j in range(n_extra):\n",
        "        sec = random.choice(SECURITY_UNIVERSE)\n",
        "        qty = round(random.uniform(10, 1000), 4)\n",
        "        price = round(random.uniform(1, 300), 4)\n",
        "        custodian_df = pd.concat([custodian_df, pd.DataFrame([{\n",
        "            \"position_id\":    f\"CST-EXTRA-{j+1:04d}\",\n",
        "            \"isin\":           sec[\"isin\"],\n",
        "            \"security_name\":  sec[\"name\"],\n",
        "            \"sector\":         sec[\"sector\"],\n",
        "            \"currency\":       sec[\"currency\"],\n",
        "            \"account_id\":     generate_account_id(random.choice(ISA_ACCOUNT_TYPES)),\n",
        "            \"account_type\":   random.choice(ISA_ACCOUNT_TYPES),\n",
        "            \"client_name\":    fake.name(),\n",
        "            \"quantity\":       qty,\n",
        "            \"unit_price\":     price,\n",
        "            \"market_value\":   round(qty * price, 2),\n",
        "            \"settlement_date\": generate_transfer_date(\"TRANSFER_IN\"),\n",
        "            \"source\":         \"CUSTODIAN\",\n",
        "        }])], ignore_index=True)\n",
        "\n",
        "    print(f\"✅ Custodian feed: {len(custodian_df):,} positions | \"\n",
        "          f\"~{len(excluded_indices)} missing (deliberately excluded)\")\n",
        "    return custodian_df\n",
        "\n",
        "\n",
        "# --- Generate datasets ---\n",
        "internal_df = generate_internal_ledger(CONFIG[\"INTERNAL_POSITIONS\"])\n",
        "custodian_df = generate_custodian_feed(internal_df)\n",
        "\n",
        "# --- Save to CSV ---\n",
        "os.makedirs(\"data\", exist_ok=True)\n",
        "internal_df.to_csv(\"data/internal_ledger.csv\", index=False)\n",
        "custodian_df.to_csv(\"data/custodian_feed.csv\", index=False)\n",
        "print(f\"\\n📁 Datasets saved to data/\")"
