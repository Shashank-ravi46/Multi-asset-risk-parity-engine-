        "    exact_matches.loc[\n",
        "        exact_matches[\"price_diff_pct\"] > tol,\n",
        "        \"break_type\"\n",
        "    ] = \"PRICE_TOLERANCE_BREACH\"\n",
        "    # Combined breaks take worst classification\n",
