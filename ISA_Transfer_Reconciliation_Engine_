        "\n",
        "    fig = px.bar(\n",
        "        sector_breaks,\n",
        "        x=\"sector\",\n",
        "        y=\"mv_at_risk\",\n",
        "        color=\"break_type\",\n",
        "        title=\"Market Value at Risk by Sector & Break Type\",\n",
        "        labels={\"mv_at_risk\": \"Market Value at Risk (£)\", \"sector\": \"Sector\"},\n",
        "        barmode=\"stack\",\n",
        "    )\n",
        "    fig.update_layout(\n",
        "        title_x=0.5, height=500, template=\"plotly_white\",\n",
        "        xaxis_tickangle=-30\n",
        "    )\n",
        "    fig.write_html(\"outputs/sector_exposure.html\")\n",
        "    fig.show()\n",
        "    print(\"✅ Sector exposure chart saved\")\n",
        "\n",
        "\n",
        "# Run all charts\n",
        "plot_waterfall(master_report)\n",
        "plot_break_distribution(master_report)\n",
        "plot_discrepancy_scatter(master_report)\n",
        "plot_sector_exposure(master_report)\n"
