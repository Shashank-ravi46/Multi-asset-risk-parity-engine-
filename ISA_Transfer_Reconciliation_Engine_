        "                    \"int_security_name\":  int_name,\n",
        "                    \"cst_security_name\":  matched_name,\n",
        "                    \"fuzzy_score\":        round(score, 2),\n",
        "                    \"match_type\":         \"FUZZY_NAME_MATCH\",\n",
        "                    \"break_type\":         \"NAMING_CONVENTION_BREAK\",\n",
        "                })\n",
        "            else:\n",
        "                unmatched_indices.append(idx)\n",
        "        else:\n",
        "            unmatched_indices.append(idx)\n",
        "\n",
        "    fuzzy_df  = pd.DataFrame(fuzzy_results)\n",
