        "    breaks[\"price_diff_pct\"] = breaks[\"price_diff_pct\"].fillna(0) * 100  # Convert to %\n",
        "\n",
        "    fig = px.scatter(\n",
        "        breaks,\n",
        "        x=\"qty_diff_abs\",\n",
        "        y=\"price_diff_pct\",\n",
        "        color=\"break_type\",\n",
        "        size=\"int_mv\",\n",
        "        size_max=30,\n",
        "        hover_data=[\"isin\", \"security_name\", \"account_id\", \"currency\"],\n",
        "        title=\"Quantity vs Price Discrepancy (bubble = market value at risk)\",\n",
        "        labels={\n",
        "            \"qty_diff_abs\":   \"Absolute Quantity Difference\",\n",
        "            \"price_diff_pct\": \"Price Difference (%)\",\n",
        "        },\n",
        "        color_discrete_map={\n",
        "            \"QUANTITY_MISMATCH\":        \"#FFD700\",\n",
        "            \"PRICE_TOLERANCE_BREACH\":   \"#FFA500\",\n",
        "            \"QUANTITY_AND_PRICE_BREAK\": \"#DC143C\",\n",
        "        }\n",
        "    )\n",
        "\n",
        "    # Add 0.5% price tolerance line\n",
        "    fig.add_hline(\n",
        "        y=0.5,\n",
        "        line_dash=\"dash\",\n",
        "        line_color=\"#DC143C\",\n",
        "        annotation_text=\"0.5% Price Tolerance\",\n",
        "        annotation_position=\"right\"\n",
        "    )\n",
        "\n",
        "    fig.update_layout(\n",
        "        title_x=0.5, height=500, template=\"plotly_white\"\n",
        "    )\n",
        "    fig.write_html(\"outputs/discrepancy_scatter.html\")\n",
        "    fig.show()\n",
        "    print(\"✅ Discrepancy scatter saved\")\n",
        "\n",
        "# ── CHART 4: BAR — Sector Break Exposure ─────────────────────\n",
        "def plot_sector_exposure(master_df: pd.DataFrame):\n",
        "    sector_breaks = master_df[\n",
        "        master_df[\"break_type\"] != \"CLEAN_MATCH\"\n",
        "    ].groupby([\"sector\", \"break_type\"]).agg(\n",
