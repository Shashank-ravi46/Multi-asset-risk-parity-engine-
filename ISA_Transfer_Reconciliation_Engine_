        "\n",
        "    # Key columns that should match exactly\n",
        "    merge_keys = [\"isin\", \"account_id\"]\n",
        "\n",
        "    # Outer join: preserves all rows from both sides\n",
        "    merged = pd.merge(\n",
        "        int_prep[merge_keys + list(int_cols.values()) +\n",
        "                 [\"account_type\", \"currency\", \"sector\", \"client_name\"]],\n",
        "        cst_prep[merge_keys + list(cst_cols.values())],\n",
        "        on=merge_keys,\n",
        "        how=\"outer\",\n",
        "        indicator=True,          # Adds _merge column: left_only / right_only / both\n",
        "    )\n",
        "\n",
        "    # --- Split into match categories ---\n",
        "    exact_matches    = merged[merged[\"_merge\"] == \"both\"].copy()\n",
        "    missing_custodian = merged[merged[\"_merge\"] == \"left_only\"].copy()   # In internal, not custodian\n",
        "    missing_internal  = merged[merged[\"_merge\"] == \"right_only\"].copy()  # In custodian, not internal\n",
