        "    print(f\"\\n  📊 COVERAGE METRICS\")\n",
        "    print(f\"  {'Internal positions processed:':<40} {len(internal_df):>8,}\")\n",
        "    print(f\"  {'Custodian positions processed:':<40} {len(custodian_df):>8,}\")\n",
        "    print(f\"  {'Total reconciliation records:':<40} {total:>8,}\")\n",
        "    print(f\"\\n  ✅ MATCH QUALITY\")\n",
        "    print(f\"  {'Clean match rate:':<40} {clean/total*100:>7.2f}%\")\n",
        "    print(f\"  {'Positions recovered via fuzzy:':<40} {fuzzy_rec:>8,}\")\n",
        "    print(f\"  {'P1 Critical breaks:':<40} {p1_breaks:>8,}\")\n",
        "    print(f\"  {'P2 Medium breaks:':<40} {p2_breaks:>8,}\")\n",
        "    print(f\"\\n  💰 FINANCIAL EXPOSURE\")\n",
        "    print(f\"  {'Total internal book value:':<40} £{total_mv_internal:>12,.0f}\")\n",
        "    print(f\"  {'Market value at risk (breaks):':<40} £{mv_at_risk:>12,.0f}\")\n",
