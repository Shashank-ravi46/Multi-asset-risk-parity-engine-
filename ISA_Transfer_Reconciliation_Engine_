        "# ============================================================\n",
        "# CELL 9: PERFORMANCE METRICS & KPI SUMMARY\n",
        "# Quantified output suitable for resume and recruiter pitch\n",
        "# ============================================================\n",
        "\n",
        "def print_kpi_dashboard(master_df: pd.DataFrame,\n",
        "                        internal_df: pd.DataFrame,\n",
        "                        custodian_df: pd.DataFrame):\n",
        "\n",
        "    bt = master_df[\"break_type\"].value_counts()\n",
        "    total      = len(master_df)\n",
        "    clean      = bt.get(\"CLEAN_MATCH\", 0)\n",
        "    p1_breaks  = master_df[master_df[\"break_priority\"] == \"P1_CRITICAL\"].shape[0]\n",
        "    p2_breaks  = master_df[master_df[\"break_priority\"] == \"P2_MEDIUM\"].shape[0]\n",
        "    fuzzy_rec  = master_df[master_df[\"match_stage\"] == \"FUZZY\"].shape[0]\n",
        "\n",
        "    total_mv_internal = internal_df[\"market_value\"].sum()\n",
        "    mv_at_risk = master_df[\n",
        "        master_df[\"break_type\"] != \"CLEAN_MATCH\"\n",
        "    ][\"int_mv\"].abs().sum()\n",
        "\n",
        "    print(\"\\n\" + \"═\" * 60)\n",
        "    print(\"  ISA RECONCILIATION ENGINE — KPI DASHBOARD\")\n",
