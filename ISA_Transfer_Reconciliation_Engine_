        "\n",
        "    cst_names = missing_internal[\"cst_security_name\"].fillna(\"\").tolist()\n",
        "    cst_isins  = missing_internal[\"isin\"].tolist()\n",
        "\n",
        "    for idx, row in missing_custodian.iterrows():\n",
        "        int_name = str(row.get(\"int_security_name\", \"\"))\n",
        "        int_isin = row[\"isin\"]\n",
        "\n",
        "        # First: check for ISIN match (account_id differs — transfer routing error)\n",
        "        isin_matches = missing_internal[missing_internal[\"isin\"] == int_isin]\n",
        "\n",
        "        if not isin_matches.empty:\n",
        "            # ISIN matches but account_id differs → likely transfer routing break\n",
        "            best_row = isin_matches.iloc[0]\n",
        "            fuzzy_results.append({\n",
        "                \"int_position_id\":    row.get(\"int_position_id\", \"\"),\n",
        "                \"cst_position_id\":    best_row.get(\"cst_position_id\", \"\"),\n",
